{% comment %}
  Renders product buy-buttons.
  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} product form id.
  - section_id: {String} id of section to which this snippet belongs.
  - show_pickup_availability: {Boolean} for the pickup availability. If true the pickup availability is rendered, false - not rendered (optional).

  Usage:
  {% render 'buy-buttons', block: block, product: product, product_form_id: product_form_id, section_id: section.id, show_pickup_availability: true %}
{% endcomment %}
<div {{ block.shopify_attributes }}>
  {%- if product != blank -%}
    {%- liquid
      assign gift_card_recipient_feature_active = false
      if block.settings.show_gift_card_recipient and product.gift_card?
        assign gift_card_recipient_feature_active = true
      endif

      assign show_dynamic_checkout = false
      if block.settings.show_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      elsif force_dynamic_checkout and gift_card_recipient_feature_active == false
        assign show_dynamic_checkout = true
      endif
    -%}
    {%- liquid
      assign giftbox_meta = product.metafields.global.add_gift_product
      assign gift_product_obj = giftbox_meta.value

      if gift_product_obj.first
        assign gift_product_obj = gift_product_obj.first
      endif

      if gift_product_obj == blank and giftbox_meta != blank
        assign gift_product_obj = all_products[giftbox_meta]
      endif

      # Fallback to default gift box product handle
      if gift_product_obj == blank
        assign default_gift_handle = 'laib-limited-gift-box'
        assign gift_product_obj = all_products[default_gift_handle]
      endif

      # Check if gift box is available (quantity > 0) and is not the current product itself
      assign has_giftbox = false
      if gift_product_obj != blank and gift_product_obj.handle != product.handle and gift_product_obj.available
        assign has_giftbox = true
      endif
    -%}
    <product-form
      class="product-form"
      data-hide-errors="{{ gift_card_recipient_feature_active }}"
      data-section-id="{{ section.id }}"
      data-has-giftbox="{% if has_giftbox %}true{% else %}false{% endif %}"
      data-giftbox-id="{{ gift_product_obj.id }}"
      data-giftbox-variant-id="{{ gift_product_obj.selected_or_first_available_variant.id | default: gift_product_obj.variants.first.id }}"
      data-giftbox-price="{{ gift_product_obj.price }}"
      data-giftbox-price-text="{{ gift_product_obj.price | money }}"
    >
      <style>
        html body .giftbox-checkbox-wrapper {
          display: flex !important;
        }
      </style>
      <div class="product-form__error-message-wrapper" role="alert" hidden>
        <svg
          aria-hidden="true"
          focusable="false"
          class="icon icon-error"
          viewBox="0 0 13 13"
        >
          <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
          <circle cx="6.5" cy="6.5" r="5.5" fill="#EB001B" stroke="#EB001B" stroke-width="0.7"/>
          <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
          <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="#EB001B" stroke-width="0.7">
        </svg>
        <span class="product-form__error-message"></span>
      </div>

      {%- form 'product',
        product,
        id: product_form_id,
        class: 'form',
        novalidate: 'novalidate',
        data-type: 'add-to-cart-form'
      -%}
        {%- assign initial_variant = target_default_variant | default: product.selected_or_first_available_variant -%}
        <input
          type="hidden"
          name="id"
          value="{{ initial_variant.id }}"
          {% if initial_variant.available == false or quantity_rule_soldout or initial_variant == null %}
            disabled
          {% endif %}
          class="product-variant-id"
        >

        {%- if gift_card_recipient_feature_active -%}
          {%- render 'gift-card-recipient-form', product: product, form: form, section: section -%}
        {%- endif -%}

        {% comment %} Customization UI moved to separate block in main-product.liquid {% endcomment %}

        {%- if has_giftbox -%}
          <style>
            .giftbox-checkbox-wrapper {
              margin-bottom: 2.2rem;
              border: 1px solid rgba(var(--color-foreground), 0.08);
              border-radius: 8px;
              background: rgba(var(--color-foreground), 0.015);
              padding: 14px 12px;
              display: flex;
              align-items: center;
              gap: 12px;
              cursor: pointer;
              transition: background 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
              box-sizing: border-box;
            }
            .giftbox-checkbox-wrapper:hover {
              background: rgba(var(--color-foreground), 0.035) !important;
              border-color: rgba(var(--color-foreground), 0.15) !important;
              box-shadow: 0 2px 8px rgba(var(--color-foreground), 0.04);
            }

            @media screen and (max-width: 480px) {
              .giftbox-checkbox-wrapper {
                padding: 10px 12px;
                gap: 12px;
              }
              .giftbox-checkbox-wrapper label {
                font-size: 1.2rem !important;
              }
              .giftbox-checkbox-wrapper span {
                font-size: 0.85rem !important;
              }
              .giftbox-checkbox-price {
                font-size: 1rem !important;
                padding: 1px 8px !important;
              }
            }
          </style>

          <div
            class="giftbox-checkbox-wrapper"
            onclick="const cb = this.querySelector('input[type=checkbox]'); cb.checked = !cb.checked; cb.dispatchEvent(new Event('change'));"
          >
            <input
              type="checkbox"
              id="GiftBoxConfirmCheckbox-{{ section_id }}"
              name="giftbox_confirm"
              style="
                width: 2.8rem;
                height: 2.8rem;
                cursor: pointer;
                margin: 0;
                accent-color: rgb(var(--color-keyboard-focus));
                flex-shrink: 0;
              "
              onclick="event.stopPropagation();"
            >

            <div style="display: flex; flex-direction: column; gap: 4px; flex-grow: 1; min-width: 0;">
              <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px; width: 100%;">
                <label
                  for="GiftBoxConfirmCheckbox-{{ section_id }}"
                  style="
                    font-size: 1.25rem;
                    font-weight: 600;
                    cursor: pointer;
                    user-select: none;
                    margin: 0;
                    line-height: 1.3;
                    color: rgb(var(--color-foreground));
                  "
                  onclick="event.stopPropagation();"
                >
                  Add Gift Box🎁
                </label>
                <span
                  class="giftbox-checkbox-price"
                  style="
                    display: none;
                    background: rgba(var(--color-foreground), 0.08);
                    padding: 2px 10px;
                    border-radius: 20px;
                    font-weight: 700;
                    font-size: 1.2rem;
                    color: rgb(var(--color-foreground));
                    white-space: nowrap;
                    flex-shrink: 0;
                  "
                ></span>
              </div>
              <span style="font-size: 0.95rem; color: rgba(var(--color-foreground), 0.6); line-height: 1.2; display: block; white-space: nowrap;">
                Premium gift packaging for the full LAIB experience
              </span>
            </div>
          </div>
        {%- endif -%}

        <div
          data-custom-total-price-wrapper
          style="display: none; padding: 1.5rem; background: rgba(var(--color-foreground), 0.03); border: 1px solid rgba(var(--color-foreground), 0.1); border-radius: 4px; margin-bottom: 1.5rem; flex-direction: column; gap: 0.8rem;"
        >
          <div data-extra-logo style="display: none; justify-content: space-between; font-size: 1.3rem;">
            <span>Nationality/Logo</span>
            <span data-logo-price-display></span>
          </div>
          <div data-extra-nationality style="display: none; justify-content: space-between; font-size: 1.3rem;">
            <span>Nationality/City</span>
            <span data-nationality-price-display></span>
          </div>
          <div data-extra-name-number style="display: none; justify-content: space-between; font-size: 1.3rem;">
            <span>Name & Number</span>
            <span data-name-number-price-display></span>
          </div>
          <div data-extra-giftbox style="display: none; justify-content: space-between; font-size: 1.3rem;">
            <span>Gift Box</span>
            <span data-giftbox-price-display></span>
          </div>
          <div style="display: flex; justify-content: space-between; font-weight: bold; font-size: 1.4rem; margin-top: 0.5rem; padding-top: 1rem; border-top: 1px solid rgba(var(--color-foreground), 0.1);">
            <span>Total Extra Price</span>
            <span data-final-extra-price></span>
          </div>
        </div>

        <div class="product-form__buttons">
          {%- liquid
            assign check_against_inventory = true
            if initial_variant.inventory_management != 'shopify' or initial_variant.inventory_policy == 'continue'
              assign check_against_inventory = false
            endif
            if initial_variant.quantity_rule.min > initial_variant.inventory_quantity and check_against_inventory
              assign quantity_rule_soldout = true
            endif
          -%}
          <button
            id="ProductSubmitButton-{{ section_id }}"
            type="submit"
            name="add"
            class="product-form__submit button button--full-width {% if show_dynamic_checkout %}button--secondary{% else %}button--primary{% endif %}"
            {% if initial_variant.available == false or quantity_rule_soldout or initial_variant == null %}
              disabled
            {% endif %}
          >
            <span>
              {%- if initial_variant == null -%}
                {{ 'products.product.unavailable' | t }}
              {%- elsif initial_variant.available == false or quantity_rule_soldout -%}
                {{ 'products.product.sold_out' | t }}
              {%- else -%}
                {{ 'products.product.add_to_cart' | t }}
              {%- endif -%}
            </span>
            {%- render 'loading-spinner' -%}
          </button>
          {%- if show_dynamic_checkout -%}
            {%- if product.tags contains 'custom_pdp' -%}
              <button
                type="button"
                class="button button--primary custom-buy-now-btn custom-buy-now-btn-gold"
                style="transition: opacity 0.2s;"
                {% if product.selected_or_first_available_variant.available == false
                  or quantity_rule_soldout
                  or product.selected_or_first_available_variant == null
                %}
                  disabled
                {% endif %}
              >
                Buy it now
              </button>
            {%- else -%}
              {{ form | payment_button }}
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endform -%}
    </product-form>
  {%- else -%}
    <div class="product-form">
      <div class="product-form__buttons form">
        <button
          type="submit"
          name="add"
          class="product-form__submit button button--full-width button--primary"
          disabled
        >
          {{ 'products.product.sold_out' | t }}
        </button>
      </div>
    </div>
  {%- endif -%}

  {%- if show_pickup_availability -%}
    {{ 'component-pickup-availability.css' | asset_url | stylesheet_tag }}

    {%- assign pick_up_availabilities = product.selected_or_first_available_variant.store_availabilities
      | where: 'pick_up_enabled', true
    -%}

    <pickup-availability
      class="product__pickup-availabilities quick-add-hidden"
      {% if product.selected_or_first_available_variant.available and pick_up_availabilities.size > 0 %}
        available
      {% endif %}
      data-root-url="{{ routes.root_url }}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
      data-product-page-color-scheme="gradient color-{{ section.settings.color_scheme }}"
    >
      <template>
        <pickup-availability-preview class="pickup-availability-preview">
          {% render 'icon-unavailable' %}
          <div class="pickup-availability-info">
            <p class="caption-large">{{ 'products.product.pickup_availability.unavailable' | t }}</p>
            <button class="pickup-availability-button link link--text underlined-link">
              {{ 'products.product.pickup_availability.refresh' | t }}
            </button>
          </div>
        </pickup-availability-preview>
      </template>
    </pickup-availability>

    <script src="{{ 'pickup-availability.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}
</div>
