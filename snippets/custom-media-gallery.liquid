{% comment %}
  Renders a custom product media gallery if product tags contain "custom"
  Accepts:
  - product: {Object} Product liquid object
{% endcomment %}

<div class="product__media-gallery custom-media-gallery{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}">
  <style>
    .custom-media-controls button:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }
  </style>

  <div class="custom-media-images" style="width: 100%; max-width: 650px; margin: 0 auto; overflow: hidden;">
    <div id="media-slider-wrapper" style="display: flex; transition: transform 0.4s ease-in-out; width: {% if product.media[1] != blank %}200%{% else %}100%{% endif %};">
      {%- if product.media[0] != blank -%}
        <div id="custom-media-front" style="width: {% if product.media[1] != blank %}50%{% else %}100%{% endif %}; flex-shrink: 0; position: relative;">
        <div class="global-media-settings" style="width: 100%; aspect-ratio: 1 / 1;">
          {{ product.media[0].preview_image | image_url: width: 1000 | image_tag: style: 'width: 100%; height: 100%; object-fit: contain; border-radius: var(--media-radius, 0);', loading: 'eager', alt: product.media[0].alt }}
        </div>
        {%- if product.tags contains 'custom-flags' -%}
          <div id="PreviewFlagFrontContainer" style="position: absolute; top: 43%; right: 37%; width: 9%; border: 1px solid rgba(0,0,0,0.1); border-radius: 2px; overflow: hidden; display: none;">
            <img id="PreviewFlagFront" src="{{ 'transparent.png' | asset_url }}" width="100%" height="auto" style="display: block;">
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
    {%- if product.media[1] != blank -%}
      <div id="custom-media-back" style="width: 50%; flex-shrink: 0; position: relative;">
        <div class="global-media-settings" style="width: 100%; aspect-ratio: 1 / 1;">
          {{ product.media[1].preview_image | image_url: width: 1000 | image_tag: style: 'width: 100%; height: 100%; object-fit: contain; border-radius: var(--media-radius, 0);', loading: 'lazy', alt: product.media[1].alt }}
        </div>
        {%- if product.tags contains 'custom-flags' -%}
          <div id="PreviewFlagBackContainer" style="position: absolute; top: 36%; left: 50%; transform: translateX(-50%); width: 9%; border: 1px solid rgba(0,0,0,0.1); border-radius: 2px; overflow: hidden; display: none;">
            <img id="PreviewFlagBack" src="{{ 'transparent.png' | asset_url }}" width="100%" height="auto" style="display: block;">
          </div>
        {%- endif -%}
        {%- if product.tags contains 'custom-inputs' -%}
            <style>
              @font-face {
                font-family: 'Cormorant Garamond';
                font-style: normal;
                font-weight: 400 700;
                font-display: swap;
                src: url('{{ "cormorant-garamond-latin-ext.woff2" | asset_url }}') format('woff2');
                unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7, U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F, U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F, U+A720-A7FF;
              }
              @font-face {
                font-family: 'Cormorant Garamond';
                font-style: normal;
                font-weight: 400 700;
                font-display: swap;
                src: url('{{ "cormorant-garamond-latin.woff2" | asset_url }}') format('woff2');
                unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
              }
            </style>
            <div style="position: absolute; top: 45%; left: 0; right: 0; text-align: center; pointer-events: none; display: flex; flex-direction: column; align-items: center; justify-content: flex-start;">
              <span id="PreviewName" style="font-weight: bold; font-family: 'Cormorant Garamond', serif; text-transform: uppercase; color: #81828C; letter-spacing: 0.5px; line-height: 1; margin-bottom: 0.5rem;"></span>
              <span id="PreviewNumber" style="font-weight: bold; font-family: 'Cormorant Garamond', serif; color: #94959d; line-height: 1;"></span>
            </div>
            <style>
              /* PC / Desktop Device */
              @media screen and (min-width: 1025px) {
                #PreviewName { font-size: 4.5rem; }
                #PreviewName[data-char-count="5"], #PreviewName[data-char-count="6"] { font-size: 4rem; }
                #PreviewName[data-char-count="7"], #PreviewName[data-char-count="8"] { font-size: 2.9rem; }
                #PreviewName[data-char-count="9"], #PreviewName[data-char-count="10"] { font-size: 2.6rem; }

                #PreviewNumber { font-size: 16rem; }
                #PreviewNumber[data-char-count="2"] { font-size: 14rem; }
              }
              
              /* Tablet Device (Portrait) */
              @media screen and (min-width: 481px) and (max-width: 1024px) {
                #PreviewName { font-size: 3.5rem; }
                #PreviewName[data-char-count="5"] { font-size: 3rem; }
                #PreviewName[data-char-count="6"] { font-size: 2.5rem; }
                #PreviewName[data-char-count="7"] { font-size: 2.2rem; }
                #PreviewName[data-char-count="8"] { font-size: 2.0rem; }
                #PreviewName[data-char-count="9"], #PreviewName[data-char-count="10"] { font-size: 1.5rem; }

                #PreviewNumber { font-size: 9rem; }
                #PreviewNumber[data-char-count="2"] { font-size: 8rem; }
              }

              /* Mobile Device (Small) */
              @media screen and (max-width: 480px) {
                #PreviewNumber { font-size: 9rem; }
                #PreviewNumber[data-char-count="2"] { font-size: 8rem; }

                #PreviewName { font-size: 3.5rem; }
                #PreviewName[data-char-count="4"] { font-size: 2.8rem; }
                #PreviewName[data-char-count="5"] { font-size: 2.5rem; }
                #PreviewName[data-char-count="6"] { font-size: 2.3rem; }
                #PreviewName[data-char-count="7"], #PreviewName[data-char-count="8"] { font-size: 1.8rem; }
                #PreviewName[data-char-count="9"], #PreviewName[data-char-count="10"] { font-size: 1.5rem; }
              }
            </style>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="custom-media-controls" style="display: flex; justify-content: center; gap: 1rem; margin-top: 1.5rem;">
    {%- if product.media[0] != blank -%}
      <button id="btn-front" type="button" class="button button--secondary" style="min-width: 120px;" onclick="switchMedia('front')" disabled>Front</button>
    {%- endif -%}
    {%- if product.media[1] != blank -%}
      <button id="btn-back" type="button" class="button button--secondary" style="min-width: 120px;" onclick="switchMedia('back')">Back</button>
    {%- endif -%}
  </div>

  <script>
    function switchMedia(type) {
      const wrapper = document.getElementById('media-slider-wrapper');
      const btnFront = document.getElementById('btn-front');
      const btnBack = document.getElementById('btn-back');

      if (!wrapper) return;

      if (type === 'front') {
        wrapper.style.transform = 'translateX(0)';
        if (btnFront) btnFront.disabled = true;
        if (btnBack) btnBack.disabled = false;
      } else {
        wrapper.style.transform = 'translateX(-50%)';
        if (btnFront) btnFront.disabled = false;
        if (btnBack) btnBack.disabled = true;
      }
    }
  </script>
</div>
