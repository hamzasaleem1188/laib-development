{% layout none %}
{%- liquid
  assign search_handle = search.terms | escape
  assign found_product = all_products[search_handle]
-%}
{%- if found_product != blank -%}
{
  "id": {{ found_product.id }},
  "title": {{ found_product.title | json }},
  "handle": {{ found_product.handle | json }},
  "url": {{ found_product.url | json }},
  "available": {{ found_product.available | json }},
  "featured_image": {{ found_product.featured_image | image_url: width: 400 | json }},
  "price": {{ found_product.price | json }},
  "price_formatted": {{ found_product.price | money | json }},
  "variants": [
    {%- for variant in found_product.variants -%}
      {
        "id": {{ variant.id }},
        "title": {{ variant.title | json }},
        "price": {{ variant.price | json }},
        "price_formatted": {{ variant.price | money | json }},
        "available": {{ variant.available | json }}
      }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
{%- else -%}
{
  "error": "Product not found",
  "searched_handle": {{ search_handle | json }}
}
{%- endif -%}
