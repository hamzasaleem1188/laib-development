{{ 'trust-banner.css' | asset_url | stylesheet_tag }}

<div class="trust-banner-section page-width">
  <div class="trust-banner-container">
    {% for block in section.blocks %}
      <div class="trust-banner-item" {{ block.shopify_attributes }}>
        <div class="trust-banner-icon">
          {{ block.settings.icon_svg }}
        </div>
        <div class="trust-banner-text">
          <div class="trust-banner-title">{{ block.settings.title }}</div>
          <div class="trust-banner-subtitle">{{ block.settings.subtitle }}</div>
        </div>
      </div>
      {% unless forloop.last %}
        <div class="trust-banner-divider"></div>
      {% endunless %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Trust Banner",
  "tag": "section",
  "class": "section",
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 3,
      "settings": [
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "30+ COUNTRIES"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Worldwide shipping"
        }
      ]
    }
  ],
  "presets": [
    {
